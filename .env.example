# Variáveis de Ambiente - Radar Solar FV
# 
# Copie este arquivo para .env e preencha com seus valores
# NUNCA commite .env no Git!
#
# Para Google Cloud Run, defina estas variáveis no console GCP
# ou via gcloud CLI: gcloud run deploy --set-env-vars KEY=VALUE

# ============================================================================
# TELEGRAM BOT
# ============================================================================

# Token do seu bot Telegram
# Obtenha em: https://t.me/BotFather
BOT_TOKEN=seu_token_aqui

# ID do seu chat Telegram (para receber relatórios)
# Para descobrir seu ID, envie /start para @userinfobot
TELEGRAM_USER_CHAT_ID=6323319651

# ============================================================================
# GOOGLE CLOUD
# ============================================================================

# ID do seu projeto GCP
# Encontre em: https://console.cloud.google.com/home/dashboard
GOOGLE_CLOUD_PROJECT=radar-solar-fv

# ============================================================================
# AMBIENTE
# ============================================================================

# Ambiente de execução
NODE_ENV=production

# Porta do servidor (Cloud Run usa 8080)
PORT=8080

# ============================================================================
# OPCIONAL: NEWS API
# ============================================================================

# Se quiser integrar com NewsAPI para buscar notícias reais
# Obtenha em: https://newsapi.org
NEWS_API_KEY=sua_chave_aqui

# ============================================================================
# OPCIONAL: LLM / MANUS API
# ============================================================================

# Se quiser usar LLM para análise inteligente
MANUS_API_KEY=sua_chave_aqui
MANUS_API_URL=https://api.manus.im

# ============================================================================
# LOGGING
# ============================================================================

# Nível de log (debug, info, warn, error)
LOG_LEVEL=info

# ============================================================================
# NOTAS
# ============================================================================

# 1. NUNCA compartilhe seus tokens/chaves
# 2. Use Secret Manager do GCP para credenciais sensíveis
# 3. Revise permissões regularmente
# 4. Faça backup de dados importantes
